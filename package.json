{
  "name": "postmd",
  "version": "1.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Web-based Markdown-to-poster editor with live preview, themes, and image export.",
  "homepage": "https://vv13.github.io/postmd",
  "repository": {
    "type": "git",
    "url": "https://github.com/vv13/postmd"
  },
  "bugs": {
    "url": "https://github.com/vv13/postmd/issues"
  },
  "keywords": [
    "markdown",
    "image",
    "poster",
    "react",
    "vite",
    "tailwindcss",
    "typescript"
  ],
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --p ./tsconfig-build.json && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "vite build --base /postmd/ && gh-pages -d dist"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.12",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "gh-pages": "^6.3.0",
    "path": "^0.12.7",
    "postcss": "^8.4.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.3",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "katex": "^0.16.45",
    "modern-screenshot": "^4.4.39",
    "react-markdown": "^9.0.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.3.0"
  }
}
